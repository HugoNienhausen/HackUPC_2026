  "flow": {
    "mermaid": "sequenceDiagram\n  participant Client\n  participant GWController as ApiGatewayController\n  participant CustClient as CustomersServiceClient\n  participant VisitClient as VisitsServiceClient\n  participant OwnerResource as OwnerResource\n  participant OwnerRepo as OwnerRepository\n  participant CustDB as customers-db\n  participant VisitResource as VisitResource\n  participant VisitRepo as VisitRepository\n  participant VisitDB as visits-db\n\n  Client->>GWController: GET /api/gateway/owners/{ownerId}\n  GWController->>CustClient: getOwner(ownerId)\n  CustClient->>OwnerResource: GET /owners/{ownerId} (lb)\n  OwnerResource->>OwnerRepo: findById(ownerId)\n  OwnerRepo->>CustDB: SELECT * FROM owners JOIN pets WHERE owner_id=?\n  CustDB-->>OwnerRepo: Owner + Pet rows\n  OwnerRepo-->>OwnerResource: Owner entity (with pets)\n  OwnerResource-->>CustClient: OwnerDetails JSON\n  CustClient-->>GWController: Mono<OwnerDetails>\n  GWController->>VisitClient: getVisitsForPets(petIds)\n  VisitClient->>VisitResource: GET /pets/visits?petId=... (lb)\n  VisitResource->>VisitRepo: findByPetIdIn(petIds)\n  VisitRepo->>VisitDB: SELECT * FROM visits WHERE pet_id IN (?)\n  VisitDB-->>VisitRepo: Visit rows\n  VisitRepo-->>VisitResource: List<Visit>\n  VisitResource-->>VisitClient: Visits JSON\n  VisitClient-->>GWController: Mono<Visits>\n  GWController->>GWController: merge visits into OwnerDetails.pets\n  GWController-->>Client: aggregated OwnerDetails (with PetDetails + VisitDetails)",
    "narrative": "A client calls GET /api/gateway/owners/{ownerId} on ApiGatewayController, which reactively fans out to two downstream services. CustomersServiceClient issues a load-balanced HTTP call to OwnerResource in customers-service, which queries OwnerRepository to load the Owner and its associated Pet entities from the database. Concurrently (or sequentially), VisitsServiceClient calls VisitResource in visits-service, which queries VisitRepository for all visits matching the owner's pet IDs. ApiGatewayController merges the returned Visits into each PetDetails within the OwnerDetails DTO, protected by a circuit breaker, and returns the fully aggregated owner profile to the caller.",
    "steps": [
      {
        "index": 1,
        "actor": "Client",
        "action": "Sends GET /api/gateway/owners/{ownerId} to the API gateway",
        "componentId": "api.boundary.web.ApiGatewayController",
        "details": "Entry point; handled by getOwnerDetails() on ApiGatewayController"
      },
      {
        "index": 2,
        "actor": "ApiGatewayController",
        "action": "Delegates owner fetch to CustomersServiceClient",
        "componentId": "api.application.CustomersServiceClient",
        "details": "Reactive WebClient call; returns Mono<OwnerDetails> for non-blocking composition"
      },
      {
        "index": 3,
        "actor": "CustomersServiceClient",
        "action": "Issues load-balanced HTTP GET /owners/{ownerId} to customers-service",
        "componentId": "customers.web.OwnerResource",
        "details": "Routed via Eureka (lb); handled by OwnerResource.findOwner()"
      },
      {
        "index": 4,
        "actor": "OwnerResource",
        "action": "Queries OwnerRepository for the owner and associated pets",
        "componentId": "customers.model.OwnerRepository",
        "details": "Spring Data JPA findById; executes SELECT on owners and pets tables including PetType join"
      },
      {
        "index": 5,
        "actor": "OwnerRepository",
        "action": "Returns Owner entity (with Pet and PetType collections) to OwnerResource",
        "componentId": "customers.model.Owner",
        "details": "Owner aggregates Pet entities; each Pet carries a PetType reference"
      },
      {
        "index": 6,
        "actor": "OwnerResource",
        "action": "Serialises Owner to OwnerDetails JSON and returns to CustomersServiceClient",
        "componentId": "customers.web.OwnerResource",
        "details": "Response includes pet list; propagated back to ApiGatewayController as Mono"
      },
      {
        "index": 7,
        "actor": "ApiGatewayController",
        "action": "Extracts pet IDs from OwnerDetails and delegates visit fetch to VisitsServiceClient",
        "componentId": "api.application.VisitsServiceClient",
        "details": "Fan-out call with all pet IDs; circuit breaker wraps this call for resilience"
      },
      {
        "index": 8,
        "actor": "VisitsServiceClient",
        "action": "Issues load-balanced HTTP GET /pets/visits?petId=... to visits-service",
        "componentId": "visits.web.VisitResource",
        "details": "Routed via Eureka (lb); handled by VisitResource.read()"
      },
      {
        "index": 9,
        "actor": "VisitResource",
        "action": "Queries VisitRepository for all visits matching the supplied pet IDs",
        "componentId": "visits.model.VisitRepository",
        "details": "Executes SELECT * FROM visits WHERE pet_id IN (?); returns List<Visit>"
      },
      {
        "index": 10,
        "actor": "ApiGatewayController",
        "action": "Merges Visits into OwnerDetails and returns aggregated response to client",
        "componentId": "api.boundary.web.ApiGatewayController",
        "details": "Each PetDetails in OwnerDetails is enriched with its matching List<VisitDetails> from the Visits container"
      }
    ]
  },
